#!/bin/bash
# Stub channel config generator for Helios Terminal development builds
# This replaces Warp's internal warp-channel-config tool

# Parse arguments (we ignore them for the stub, but accept them for compatibility)
while [[ $# -gt 0 ]]; do
    case $1 in
        --channel)
            CHANNEL="$2"
            shift 2
            ;;
        --target-family)
            TARGET_FAMILY="$2"
            shift 2
            ;;
        --target-os)
            TARGET_OS="$2"
            shift 2
            ;;
        *)
            shift
            ;;
    esac
done

# Output minimal valid ChannelConfig JSON
cat <<'EOF'
{
  "app_id": "dev.helios.terminal",
  "logfile_name": "helios-terminal.log",
  "server_config": {
    "server_root_url": "http://localhost:8080",
    "rtc_server_url": "ws://localhost:8080/rtc",
    "session_sharing_server_url": null,
    "firebase_auth_api_key": "stub-key-not-used"
  },
  "oz_config": {
    "oz_root_url": "http://localhost:8080/oz",
    "workload_audience_url": null
  },
  "telemetry_config": null,
  "autoupdate_config": null,
  "crash_reporting_config": null,
  "mcp_static_config": null
}
EOF
